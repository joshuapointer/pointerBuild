{
  "name": "@pointer/sdk",
  "version": "0.1.0",
  "description": "Client SDK for pointerBuild — Expo/React Native integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./expo": {
      "import": "./dist/expo.js",
      "types": "./dist/expo.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "expo",
    "react-native",
    "ota",
    "updates",
    "eas",
    "pointer"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73",
    "expo": ">=50"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-native": { "optional": true },
    "expo": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "react": "^18.3.1",
    "typescript": "^5.5.3"
  }
}
