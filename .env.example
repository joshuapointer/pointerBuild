# --- Database ---
DB_NAME=pointerbuild
DB_USER=pointer
DB_PASSWORD=change_me_strong_password

# --- MinIO / S3 ---
S3_ACCESS_KEY=change_me_access_key
S3_SECRET_KEY=change_me_secret_key
S3_REGION=us-east-1

# --- API auth (shared by pointer-updates and pointer-deploy) ---
POINTER_API_KEY=change_me_api_key

# --- Public URLs (used by clients and signed URL generation) ---
POINTER_UPDATES_PUBLIC_URL=http://localhost:3001
POINTER_DEPLOY_PUBLIC_URL=http://localhost:3002

# --- GitHub Actions integration (used by pointer-cli) ---
GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=your-github-user
GITHUB_REPO=your-repo

# --- Domain (used by nginx / TLS automation) ---
POINTER_DOMAIN=your-vps.example.com
LETSENCRYPT_EMAIL=you@example.com
